            <h2 class="text-center mb-4 text-cyan">Galeri Simulator</h2>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div id="gravityCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner rounded shadow">
                            <div class="carousel-item active">
                                <!-- SEO OPTIMIZATION: Alt text diubah agar kaya kata kunci -->
                                <img src="https://images.unsplash.com/photo-1614728894747-a83421e2b9c9?q=80&w=800&auto=format&fit=crop" class="d-block w-100" alt="Simulator luar angkasa dengan teknologi anti gravity" style="height: 400px; object-fit: cover;">
                            </div>
                            <div class="carousel-item">
                                <!-- SEO OPTIMIZATION: Alt text diubah agar kaya kata kunci -->
                                <img src="https://images.unsplash.com/photo-1506703719100-a0f3a48c0f86?q=80&w=800&auto=format&fit=crop" class="d-block w-100" alt="Uji coba ruangan tanpa bobot zero gravity" style="height: 400px; object-fit: cover;">
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#gravityCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#gravityCarousel" data-bs-slide="next">
