            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card bg-dark text-white h-100 border-secondary">
                        <div class="card-body">
                            <h5 class="card-title text-cyan">Zero-G Engine</h5>
                            <p class="card-text">Mesin pembalik polaritas medan magnet bumi untuk menciptakan area hampa tarikan.</p>
                            <span class="badge bg-danger">Hot Tech</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark text-white h-100 border-secondary">
